@{
    ViewData["Title"] = "My Bookings";
}
<link href="~/css/booking/MyBooking.css" rel="stylesheet" />
<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">My Bookings</h2>
            <p class="text-muted mb-0">
                Manage your room reservations
            </p>
        </div>

        <a asp-controller="Booking"
           asp-action="BookMeeting"
           class="btn btn-primary">

            <i class="bi bi-plus-lg"></i>
            New Booking

        </a>

    </div>

    <!-- MOBILE VIEW -->

    <div class="d-block d-lg-none">

        <div class="booking-card-mobile">

            <div class="booking-header">

                <h6>Project Review Meeting</h6>

                <span class="badge bg-success">
                    Upcoming
                </span>

            </div>

            <div class="booking-details">

                <p>
                    <i class="bi bi-door-open"></i>
                    Board Room
                </p>

                <p>
                    <i class="bi bi-calendar3"></i>
                    18 Jun 2026
                </p>

                <p>
                    <i class="bi bi-clock"></i>
                    10:00 AM - 11:30 AM
                </p>

            </div>

            <div class="booking-actions">

                <button class="btn btn-sm btn-outline-primary">
                    View
                </button>

                <button class="btn btn-sm btn-outline-danger">
                    Cancel
                </button>

            </div>

        </div>

        <div class="booking-card-mobile">

            <div class="booking-header">

                <h6>Team Standup</h6>

                <span class="badge bg-warning text-dark">
                    Pending
                </span>

            </div>

            <div class="booking-details">

                <p>
                    <i class="bi bi-door-open"></i>
                    Conference Room A
                </p>

                <p>
                    <i class="bi bi-calendar3"></i>
                    20 Jun 2026
                </p>

                <p>
                    <i class="bi bi-clock"></i>
                    02:00 PM - 03:00 PM
                </p>

            </div>

            <div class="booking-actions">

                <button class="btn btn-sm btn-outline-primary">
                    View
                </button>

            </div>

        </div>

    </div>

    <!-- DESKTOP VIEW -->

    <div class="card shadow-sm border-0 d-none d-lg-block">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>
                            <th>Meeting</th>
                            <th>Room</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>

                    </thead>

                    <tbody>

                        <tr>
                            <td>Project Review Meeting</td>
                            <td>Board Room</td>
                            <td>18-Jun-2026</td>
                            <td>10:00 AM - 11:30 AM</td>
                            <td>
                                <span class="badge bg-success">
                                    Upcoming
                                </span>
                            </td>
                            <td>

                                <button class="btn btn-sm btn-outline-primary">
                                    View
                                </button>

                                <button class="btn btn-sm btn-outline-danger">
                                    Cancel
                                </button>

                            </td>
                        </tr>

                        <tr>
                            <td>Team Standup</td>
                            <td>Conference Room A</td>
                            <td>20-Jun-2026</td>
                            <td>02:00 PM - 03:00 PM</td>
                            <td>
                                <span class="badge bg-warning text-dark">
                                    Pending
                                </span>
                            </td>
                            <td>

                                <button class="btn btn-sm btn-outline-primary">
                                    View
                                </button>

                            </td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>